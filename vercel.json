{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "env": {
    "USE_MOCK": "false"
  },
  "crons": [
    {
      "path": "/api/cron/scan",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/refresh-leaderboard",
      "schedule": "*/30 * * * *"
    }
  ]
}
